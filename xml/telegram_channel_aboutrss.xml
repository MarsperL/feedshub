VgoLS2LKoZnjXypx3TOZrgUUBfNEqVuHZWXjzkjZfkYeK0zw1l1cJ67cs3rv7pbICi6zf9VzUzGS3vf8Y3WuI_nugD_fHqrJSAY211-cQhf86tZ294GPxaF706gPwJwS2WagG3gpbCuQ9jsY2qLOzXaPGL_8jMfz1zXigPHs31jjQB8R2IhPOzAQ.jpg" width="800" height="594" referrerpolicy="no-referrer"&gt;</description><link>https://t.me/aboutrss/1521</link><guid isPermaLink="false">https://t.me/aboutrss/1521</guid><pubDate>Sat, 02 Aug 2025 04:14:19 GMT</pubDate></item><item><title>🖼 FeedMe: 一款集成 AI 摘要生成的 RSS 阅读工具</title><description>&lt;p&gt;&lt;b&gt;FeedMe: 一款集成 AI 摘要生成的 RSS 阅读工具&lt;/b&gt;&lt;br&gt;&lt;br&gt;项目 &lt;a href="https://t.me/aboutrss/1520?q=%23%E5%BC%80%E6%BA%90"&gt;#开源&lt;/a&gt;，需自部署至 GitHub Pages / Vercel / Docker；已有 500+ &lt;span class="emoji"&gt;⭐️&lt;/span&gt;&lt;br&gt;&lt;br&gt;Repo: &lt;a href="https://github.com/Seanium/feedme" target="_blank" rel="noopener"&gt;https://github.com/Seanium/feedme&lt;/a&gt;&lt;br&gt;Demo: &lt;a href="https://feedme.icu/" target="_blank" rel="noopener"&gt;https://feedme.icu/&lt;/a&gt;&lt;br&gt;&lt;br&gt;发现于&lt;br&gt;&lt;a href="https://t.me/fakeye/1645" target="_blank" rel="noopener"&gt;https://t.me/fakeye/1645&lt;/a&gt;&lt;/p&gt;&lt;img src="https://cdn1.telesco.pe/file/j5W5RWt2-bkFW94fQxqainFAN7Bzvi5dOZupAqYO77ImdWA134VJiJew11K6qbkgWV9mPKeQiGQxcBJJbnOOsj5zeTFR3pD91q19MA7BwDrAKP9huDTamElYQy80KVIvVLmCAcDc8n4hwgijm06OzaJXlcrulCUmcztG9gXMizNuAg2_OankbcydrA22TzTv_Iud5YlRj986-11BzSnihqTDrqKb7gg7RmdS7aS9D3d2gvIiL9mhg7TVNlCc2Nt6vIAZscZVK5ykWIVebkmN0zZfbZmLp6HqOjdpID4tFthWv7pwO9uf4OQmYxiaJolQ8jsL31Rl-uENfgNC0LMKqQ.jpg" width="800" height="437" referrerpolicy="no-referrer"&gt;</description><link>https://t.me/aboutrss/1520</link><guid isPermaLink="false">https://t.me/aboutrss/1520</guid><pubDate>Tue, 15 Jul 2025 07:31:20 GMT</pubDate></item><item><title>🖼 ArtFeed: 面向摄影、图像艺术的 RSS 阅读器</title><description>&lt;p&gt;&lt;b&gt;ArtFeed: 面向摄影、图像艺术的 RSS 阅读器&lt;/b&gt;&lt;br&gt;&lt;br&gt;该项目 &lt;a href="https://t.me/aboutrss/1519?q=%23%E5%BC%80%E6%BA%90"&gt;#开源&lt;/a&gt;，和 folo 的看图模式一样，也是专为图片型内容 Feed 进行了优化。&lt;br&gt;&lt;br&gt;&lt;a href="https://artfeed.org/" target="_blank" rel="noopener"&gt;https://artfeed.org/&lt;/a&gt;&lt;br&gt;&lt;br&gt;发现于作者嘟文：&lt;br&gt;&lt;a href="https://mamot.fr/@atlza/114614139934160756" target="_blank" rel="noopener"&gt;https://mamot.fr/@atlza/114614139934160756&lt;/a&gt;&lt;/p&gt;&lt;img src="https://cdn1.telesco.pe/file/pJFdqK3Ya10MWuoD2ED2waTW1vySvH8vOweWIe9U_D2ogUR4cDw6LErfyqPpPA3T61RaYeMBR3RRXzKk6I_hoRHGRkNnciID55J_4mESsI1dAWi-lD549hIeSn2xZ9mTEV050ZSvCdWEsXTuCv707deXknvM1b32gQxHU_vAHYFHGJvdm1TIMjuj6SyNUDVRyRPc6krBq1QEPGoy9ALH5Zv0hg7T4ssSt5TfB6jYw-ykLtwgZYhvzed-G7Hut3K9hoW4rQviAn0MhhPMSunu7ij4FIUtQfP_aBS64AcShey8ntYPfmf4Hvy6d5C8jVNRsGBG03xkGjU296OQIOzeYg.jpg" width="800" height="406" referrerpolicy="no-referrer"&gt;</description><link>https://t.me/aboutrss/1519</link><guid isPermaLink="false">https://t.me/aboutrss/1519</guid><pubDate>Sat, 05 Jul 2025 02:02:50 GMT</pubDate></item><item><title>🖼 RSS Gizmos 作者最近的 3 个 RSS 玩法</title><description>&lt;p&gt;&lt;b&gt;RSS Gizmos 作者最近的 3 个 RSS 玩法&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;a href="https://t.me/aboutrss/1326" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;RSS Gizmos 是频道介绍过的一个 RSS 工具箱&lt;/a&gt;，其作者 Tara Calishain 最近又有新的 RSS 花式用法：&lt;br&gt;&lt;br&gt;&lt;span class="emoji"&gt;🔸&lt;/span&gt;&lt;a href="https://searchtweaks.com/nkt/" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;No Kings TV&lt;/a&gt;：一个利用 RSS 的当地新闻展示页&lt;br&gt;根据作者&lt;a href="https://www.calishat.com/2025/06/13/no-kings-tv/" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;日志&lt;/a&gt;，其主要拿该工具追踪美国当地抗议活动、对抗谣言，方法是自选可靠信源，并将文字新闻和视频新闻各用一列展示。&lt;br&gt;&lt;br&gt;&lt;span class="emoji"&gt;🔸&lt;/span&gt;&lt;a href="https://mastogizmos.com/rss.html" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;RSStodon&lt;/a&gt;：为 &lt;a href="https://t.me/aboutrss/1518?q=%23Mastodon"&gt;#Mastodon&lt;/a&gt; 上的标签生成 RSS Feed&lt;br&gt;RSStodon 是作者 Mastodon 工具箱 MastoGizmos 中的一个工具。&lt;br&gt;&lt;br&gt;&lt;span class="emoji"&gt;🔸&lt;/span&gt;&lt;a href="https://www.calishat.com/2025/06/11/rss-with-an-expiration-date-the-temporary-obsessions-feed-reader/" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;The Temporary Obsessions Feed Reader&lt;/a&gt;：面向时效信息的 RSS 订阅玩法&lt;br&gt;Calishain 巧妙利用 Google Sheet 和 Gmail 给 RSS 订阅加了一个定时开关，让基于 RSS 的信息获取仅在设定的日期范围内执行，特别适合追踪一些有时效的事件型信息或只是临时关注的主题。&lt;/p&gt;&lt;img src="https://cdn1.telesco.pe/file/ogZbVL6GTcgFa3PMzIRhRYX-JlCjAwuT8Da5i5s295ki0jEM-1Qdt68DrATRcZviqw50FGIprGERYcO6HgdK-re4JGMk4H68j4qFDtl7OtX2dt-xahRFRNQo5yIYT-MaeAn3oUwCtvG0_9yz3s1666NXPKJVXlmZCzRAnsVdU7-P6iN1YZZ4mlgqsXw9foMcNwaeMqYsJV5NWnl5hzWA2eYgxJnpgNZXacTo1djs0fGqwicbYcSFyQk4boN8UeV5HRSWQ3jpHeORWp2xlwv7CxC6toTFK3japGHkIHAOYQDY1Uc1QmqxpnIdaWGzZ773vpOjEAvGsbQtPXazh_YDOA.jpg" width="800" height="512" referrerpolicy="no-referrer"&gt;</description><link>https://t.me/aboutrss/1518</link><guid isPermaLink="false">https://t.me/aboutrss/1518</guid><pubDate>Wed, 02 Jul 2025 12:01:09 GMT</pubDate></item><item><title>🖼 Django-link-archive: #开源 可自架的链接收藏管理查找工具</title><description>&lt;p&gt;&lt;b&gt;Django-link-archive: &lt;/b&gt;&lt;a href="https://t.me/aboutrss/1517?q=%23%E5%BC%80%E6%BA%90"&gt;&lt;b&gt;#开源&lt;/b&gt;&lt;/a&gt;&lt;b&gt; 可自架的链接收藏管理查找工具&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;u&gt;感谢&lt;/u&gt;&lt;a href="https://github.com/AboutRSS/ALL-about-RSS/pull/104" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;&lt;u&gt;开发者提交 PR&lt;/u&gt;&lt;/a&gt;，分享了其开发的支持 RSS 的 bookmarking 工具：Django-link-archive。该项目 &lt;a href="https://t.me/aboutrss/1517?q=%23%E5%BC%80%E6%BA%90"&gt;#开源&lt;/a&gt; 可自架，支持 RSS 订阅。&lt;br&gt;&lt;br&gt;&lt;a href="https://rumca-js.github.io/quickstart/public/static_lists/viewerzip.html" target="_blank" rel="noopener"&gt;https://rumca-js.github.io/quickstart/public/static_lists/viewerzip.html&lt;/a&gt;&lt;br&gt;&lt;br&gt;&lt;a href="https://t.me/aboutrss/1509" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;跳转频道上次提及的支持 #RSS2Bookmark 或 #Bookmark2RSS 的工具。&lt;/a&gt;&lt;/p&gt;&lt;img src="https://cdn1.telesco.pe/file/QJF-IhHxKklHOTfcWZwdoJU3cy3VIE1fi5gK0l7q_emBhbMPGEEJuKK26BN0NZaD2gZj6U9__f-xnfs4b2CdJYxUBK40nPa2ALRRFgEc8w6xzrQKigtmuPX7hE2q5BOjtp0tkQRp_ZfGbTHyESFqWlacIZ9UklEejqgVVYGePLf6vjAJoAh_wvw3aqds8zLQAM29gVTlWqa4Jx6taVjNnqtJwtNuAr_XoSCuFWfXif-pPSf6ToGAiqtESV6OIAYK_sDJXX74-zgiWy8adHt5L1ni9o097hlPic3qCD6MuoLt697ED_YShaMKSU7kfR7NgM1w3bb9dqPfY_L_TYaT1g.jpg" width="800" height="459" referrerpolicy="no-referrer"&gt;</description><link>https://t.me/aboutrss/1517</link><guid isPermaLink="false">https://t.me/aboutrss/1517</guid><pubDate>Tue, 17 Jun 2025 12:03:13 GMT</pubDate></item><item><title>↩️ 分享 RSSFlow Reader 十枚激活码</title><description>&lt;div class="rsshub-quote"&gt;&lt;blockquote&gt; &lt;p&gt;&lt;a href="https://t.me/aboutrss/1508"&gt;&lt;b&gt;ALL About RSS&lt;/b&gt;:&lt;/a&gt;&lt;/p&gt; &lt;p&gt;RSSFlow Reader: 一款有 AI 加持的浏览器扩展版 RSS 阅读器 RSSFlow Reader 是一个 #浏览器扩展，主打基于 #AI 和多种版式的阅读体验提升： 官网主页：https://oinzen.github.io/RSSFlow-doc/ 用户交流群：https://t.me/+fTK4yn1n3aU5YWFl 发现于作者推文： https://x.com/rssflow_zen/status/1881900652827419006&lt;/p&gt; &lt;/blockquote&gt;&lt;/div&gt;&lt;p&gt;&lt;b&gt;分享 RSSFlow Reader 十枚激活码&lt;/b&gt;&lt;br&gt;&lt;br&gt;频道 4 月介绍了 &lt;a href="https://t.me/aboutrss/1508" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;RSSFlow Reader&lt;/a&gt;，此后作者又密集更新了一波，增加了基于 AI 的聊天对话模式等功能，详见其&lt;a href="https://t.me/+fTK4yn1n3aU5YWFl" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;用户交流群&lt;/a&gt;。这次作者赠送了 10 枚激活码，我将于北京时间今晚8点整定时发至频道内群 &lt;a href="https://t.me/ALLaboutRSS" target="_blank"&gt;@ALLaboutRSS&lt;/a&gt;，先到先得。在接下来的几个小时内，感兴趣的朋友可以先了解和试用，看看是否是自己需要的。需注意的是，需要填入大模型 API 并使用 1 次 AI 功能方可让激活入口显现。届时若使用了激活码，还请回复一下已用。感谢开发者分享！&lt;span class="emoji"&gt;🌹&lt;/span&gt;&lt;/p&gt;&lt;blockquote&gt;&lt;b&gt;Telegram&lt;/b&gt;&lt;br&gt;&lt;b&gt;&lt;a href="https://t.me/aboutrss/1508"&gt;ALL About RSS&lt;/a&gt;&lt;/b&gt;&lt;br&gt;&lt;p&gt;RSSFlow Reader: 一款有 AI 加持的浏览器扩展版 RSS 阅读器&lt;br&gt;&lt;br&gt;RSSFlow Reader 是一个 #浏览器扩展，主打基于 #AI 和多种版式的阅读体验提升：&lt;br&gt;&lt;br&gt;官网主页：https://oinzen.github.io/RSSFlow-doc/&lt;br&gt;用户交流群：https://t.me/+fTK4yn1n3aU5YWFl&lt;br&gt;&lt;br&gt;发现于作者推文：&lt;br&gt;https://x.com/rssflow_zen/status/1881900652827419006&lt;/p&gt;&lt;img src="https://cdn1.telesco.pe/file/oKlH-NPfUMpnNHyvJe64I2aQAjZchskpDF4Gc2GfccOvqP2LEbYQYq8enDWcljkiVsrq9tUk8Qmyf_A45E5xhpvMwP9cBYinBxJrd9QxFsoDQ8YNlF1BkKaB6cBeQgaeeuWMZurTTBxU9CCFQL7SzLd4lU2vK8PAWJ0HQNPgw9GjSMGCEOgp-ByAYp36wQP7GxBh0MBAsLOoXQVOWBLpzDdWEytzZoxBWez-Kq5Z9wOovvj9Sl1KMOfZiZq6K2YCBaB0DU5M0C7a1PpGsI_9KQ4p5bs-trrb0RXaDi9K91qXc0NMpjqAt2H82uE3iyX9ghGH2DBnBM2jktu8dCpc_Q.jpg" referrerpolicy="no-referrer"&gt;&lt;/blockquote&gt;</description><link>https://t.me/aboutrss/1516</link><guid isPermaLink="false">https://t.me/aboutrss/1516</guid><pubDate>Fri, 13 Jun 2025 08:02:41 GMT</pubDate></item><item><title>↩️🖼 Folo 推出安卓版 App</title><description>&lt;div class="rsshub-quote"&gt;&lt;blockquote&gt; &lt;p&gt;&lt;a href="https://t.me/aboutrss/1505"&gt;&lt;b&gt;ALL About RSS&lt;/b&gt;:&lt;/a&gt;&lt;/p&gt; &lt;p&gt;Follow App 更名为 Folo 并推出 iOS APP Natural Selection Labs 出品的 “下一代信息浏览器” Follow 更名为 #Folo 并上线了免费且 #开源 的 iOS App： &lt;span class="emoji"&gt;📱&lt;/span&gt;https://apps.apple.com/app/folo-follow-everything/id6739802604 &lt;span class="emoji"&gt;🐙&lt;/span&gt;https://github.com/RSSNext/Folo/tree/dev/apps/mobile 借助代币 $POWER ，Folo 目前支持： …&lt;/p&gt; &lt;/blockquote&gt;&lt;/div&gt;&lt;p&gt;&lt;b&gt;Folo 推出安卓版 App&lt;/b&gt;&lt;br&gt;&lt;br&gt;经过 &lt;a href="https://x.com/follow_app_/status/1923588028603433211" target="_blank" rel="noopener" onclick="return confirm('Open this link?\n\n'+this.href);"&gt;Google Play 的内